# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local development (SQLite — no account needed):
DATABASE_URL="file:./dev.db"

# Production (Postgres/Supabase — swap provider in prisma/schema.prisma too):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ---------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# If RESEND_API_KEY is unset, email is skipped and only logged; bookings still work.
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM="BEEDS <noreply@beedstu.com>"  # must be a verified sender in Resend

# --- Analytics / Google Ads (Step 1: measurement) ---
# GA4 Measurement ID — Google Analytics > Admin > Data streams > your web stream
NEXT_PUBLIC_GA_ID=
# Google Ads tag ID — Google Ads > Goals > Conversions > Google tag (starts AW-)
NEXT_PUBLIC_GADS_ID=
# Google Ads conversion label — from the "Book a session" conversion action
NEXT_PUBLIC_GADS_CONVERSION_LABEL=
